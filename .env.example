# WORLD CUP XI — environment variables (copy to .env for local dev, and set the
# same names in Vercel → Project → Settings → Environment Variables for prod).
# NEVER commit real values. The .env file is gitignored.

# football-data.org — powers the PREDICTION layer (live match scores).
# Required for live scoring. Free token: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
# For local match-watch: copy to .env.local and run ./scripts/dev-with-api.sh
# (vercel dev --listen 4321). Plain python http.server cannot serve /api/*.

# balldontlie FIFA World Cup API — powers the DREAM XI layer
# (per-player goals / assists / clean sheets). Optional until kickoff.
# Free key: https://balldontlie.io
BALLDONTLIE_KEY=

# ——— Clerk (auth) — server side ———
# The publishable key is public and lives in index.html. These are SECRET and
# belong only in server env (already pulled to .env.local by `clerk env pull`).
#   CLERK_SECRET_KEY  — required to verify session tokens in /api/entry.
#   CLERK_JWT_KEY     — optional PEM public key for networkless verification
#                       (faster cold starts; Dashboard → API Keys → JWT public key).
#   CLERK_AUTHORIZED_PARTIES — optional, comma-separated allowed origins (prod hardening).
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=

# ——— Vercel KV / Upstash Redis — powers ENTRY persistence + leaderboards ———
# Connect an Upstash store to the Vercel project (Storage → Upstash → Redis) and
# Vercel injects these automatically. Until set, the site runs localStorage-only.
KV_REST_API_URL=
KV_REST_API_TOKEN=
